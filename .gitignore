# =============================================================================
# MT5 Forex Trading Bot — .gitignore
# =============================================================================

# --- Secrets (NEVER commit) ---
.env

# --- Log files ---
logs/
*.log

# --- Data directories (large files / generated output) ---
data/historical/
data/screenshots/
data/reports/

# --- Database files ---
*.db
*.db-wal
*.db-shm

# --- Python cache ---
__pycache__/
*.py[cod]
*.pyo
*$py.class

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Build / packaging ---
*.egg-info/
dist/
build/
*.egg
*.whl
MANIFEST

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.env.bak

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Type checking ---
.mypy_cache/
.dmypy.json
dmypy.json

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb

# --- Windows ---
desktop.ini
